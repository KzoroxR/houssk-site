---
import BaseLayout from "../layouts/BaseLayout.astro";
import { modules, site } from "../data/site";
---

<BaseLayout>
  <section class="hero section" id="accueil">
    <div class="hero-copy" data-reveal>
      <p class="eyebrow">Application mobile pour la vie à plusieurs</p>
      <h1>Le foyer, sans les messages perdus.</h1>
      <p class="lead">
        <strong>hous.sk</strong> rassemble ce qui fait tourner la maison : tâches, courses, repas, dépenses, notes, calendrier, emplois du temps et foyers partagés.
      </p>
      <div class="hero-actions">
        <a class="button button-primary" href={site.webAppUrl}>Ouvrir l'app web</a>
        <a class="button button-primary" href={site.appUrl}>Télécharger l'app</a>
        <a class="button button-secondary" href="#modules">Explorer les fonctions</a>
      </div>
      <div class="hero-meta" aria-label="Résumé">
        <span>Plusieurs foyers</span>
        <span>Partage équitable</span>
        <span>Mobile-first</span>
      </div>
    </div>

    <div class="hero-stage" aria-label="Aperçu de l'application hous.sk">
      <div class="orb orb-one" data-parallax></div>
      <div class="orb orb-two" data-parallax></div>
      <figure class="hero-phone-shot" data-parallax>
        <img src="/uploads/houssk/iPhone%2015.png" alt="Capture de l'application hous.sk sur téléphone" loading="eager" />
      </figure>
    </div>
  </section>

  <section class="section home-switch" id="foyers">
    <div class="section-heading compact" data-reveal>
      <p class="eyebrow">Foyers multiples</p>
      <h2>Une app pour chaque maison que vous organisez.</h2>
      <p>
        Votre foyer principal, une colocation, une résidence secondaire, un proche à aider : hous.sk garde les espaces séparés, mais toujours accessibles.
      </p>
    </div>
    <div class="home-board" data-reveal>
      <article class="home-card active">
        <span>🏠</span>
        <strong>Appartement</strong>
        <small>4 membres · 12 actions ouvertes</small>
      </article>
      <article class="home-card">
        <span>🌿</span>
        <strong>Maison famille</strong>
        <small>Planning, courses, repas</small>
      </article>
      <article class="home-card">
        <span>☕</span>
        <strong>Coloc</strong>
        <small>Dépenses et tâches partagées</small>
      </article>
    </div>
  </section>

  <section class="section" id="modules">
    <div class="section-heading" data-reveal>
      <p class="eyebrow">Tout ce qui finit d'habitude dans dix apps</p>
      <h2>Des modules simples, reliés entre eux.</h2>
      <p>
        hous.sk n'essaie pas de transformer la maison en tableau de bord d'entreprise. L'idée est plus directe : savoir quoi faire, qui participe, ce qu'il manque et ce qui arrive.
      </p>
    </div>
    <div class="module-grid">
      {modules.map((module) => (
        <article class="module-card" data-reveal>
          <span class="module-icon">{module.icon}</span>
          <h3>{module.title}</h3>
          <p>{module.text}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section product-lab" id="experience">
    <div class="section-heading compact" data-reveal>
      <p class="eyebrow">Interface recréée</p>
      <h2>Une sensation d'app, pas une page de screenshots.</h2>
      <p>
        Le site reprend le langage de hous.sk : cartes sombres, informations courtes, actions rapides, et un violet utilisé comme signal plutôt que comme peinture murale.
      </p>
    </div>

    <div class="lab-grid">
      <article class="mini-screen tasks-screen" data-parallax>
        <div class="screen-head">
          <span>‹</span>
          <div>
            <strong>Tâches</strong>
            <small>4 tâche(s)</small>
          </div>
          <button aria-label="Ajouter une tâche">+</button>
        </div>
        <div class="task-tabs">
          <span class="active">Toutes</span>
          <span>À faire</span>
          <span>À venir</span>
        </div>
        <div class="task-row focused">
          <i></i>
          <div>
            <small>🧹 Ménage · -1j</small>
            <strong>Passer la serpillière</strong>
            <span>En retard · tous les 7 jours</span>
          </div>
        </div>
        <div class="task-row">
          <i></i>
          <div>
            <small>🧹 Ménage · Aujourd'hui</small>
            <strong>Nettoyer le robot</strong>
          </div>
        </div>
      </article>

      <article class="mini-screen money-screen" data-parallax>
        <div class="screen-head">
          <span>‹</span>
          <div>
            <strong>Dépenses</strong>
            <small>Équilibrage du foyer</small>
          </div>
          <button aria-label="Ajouter une dépense">+</button>
        </div>
        <div class="money-stats">
          <div><small>Ce mois-ci</small><strong>460,38 €</strong></div>
          <div><small>Mon solde</small><strong class="positive">+8,40 €</strong></div>
        </div>
        <div class="refund-card">
          <small>Remboursements</small>
          <strong>John → Moi <span>8,40 €</span></strong>
        </div>
      </article>

      <article class="mini-screen meals-screen" data-parallax>
        <div class="screen-head">
          <span>‹</span>
          <div>
            <strong>Repas</strong>
            <small>Semaine en préparation</small>
          </div>
          <button aria-label="Ajouter un repas">+</button>
        </div>
        <div class="meal-line"><span>Lun</span><strong>Gratin courgettes</strong><em>+ courses</em></div>
        <div class="meal-line"><span>Mar</span><strong>Poulet curry</strong><em>recette</em></div>
        <div class="meal-line"><span>Mer</span><strong>Libre</strong><em>à définir</em></div>
        <div class="note-card">
          <small>Note de frigo</small>
          <p>Penser à sortir les draps avant vendredi.</p>
        </div>
      </article>
    </div>
  </section>

  <section class="section rhythm-section">
    <div class="rhythm-copy" data-reveal>
      <p class="eyebrow">Coordination douce</p>
      <h2>Chacun garde la main. Le foyer garde le fil.</h2>
      <p>
        Les membres peuvent participer à leur rythme : ajouter une course, créer une recette, marquer une tâche terminée, noter une dépense, consulter un planning ou partager leur position uniquement s'ils sont d'accord.
      </p>
    </div>
    <div class="timeline-card" data-reveal>
      <div><span>08:30</span><strong>École · départ</strong></div>
      <div><span>12:15</span><strong>Courses ajoutées depuis une recette</strong></div>
      <div><span>18:00</span><strong>Repas prévu : curry maison</strong></div>
      <div><span>20:30</span><strong>Dépense répartie entre 3 personnes</strong></div>
    </div>
  </section>

  <section class="section pricing" id="premium">
    <div class="section-heading compact" data-reveal>
      <p class="eyebrow">Gratuit et Premium</p>
      <h2>Commencez simplement, débloquez plus quand le foyer grandit.</h2>
      <p>
        hous.sk propose un plan gratuit pour découvrir et organiser les bases du foyer, puis un plan Premium pour aller plus loin. Les modalités exactes sont affichées dans l'application.
      </p>
    </div>
    <div class="pricing-grid">
      <article class="price-card">
        <small>Plan gratuit</small>
        <h3>Pour démarrer</h3>
        <p>Créer un foyer, tester les usages essentiels et voir si hous.sk colle à votre quotidien.</p>
      </article>
      <article class="price-card highlighted">
        <small>Premium</small>
        <h3>Pour tout centraliser</h3>
        <p>Plus de confort, plus de modules et une organisation plus complète pour les foyers qui utilisent l'app tous les jours.</p>
      </article>
    </div>
  </section>

  <section class="section final-cta">
    <div class="final-cta-card" data-reveal>
      <p class="eyebrow">À installer sur Android</p>
      <h2>Construisez votre foyer numérique, sans usine à gaz.</h2>
      <p>
        Créez votre premier foyer, invitez les bonnes personnes et commencez par une liste, une tâche ou une dépense. Le reste suit naturellement.
      </p>
      <div class="hero-actions">
        <a class="button button-primary" href={site.webAppUrl}>Ouvrir l'app web</a>
        <a class="button button-secondary" href={site.appUrl}>Télécharger sur Google Play</a>
        <a class="button button-secondary" href="/confidentialite">Confidentialité</a>
      </div>
    </div>
  </section>
</BaseLayout>
